{
  "name": "tradescribe",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "grant-admin": "tsx tools/grant-admin.ts",
    "db:generate": "pnpm --filter @tradescribe/db generate",
    "db:migrate": "pnpm --filter @tradescribe/db migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "@next/eslint-plugin-next": "15.1.3",
    "eslint-config-next": "15.1.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
