# Core
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradescribe"
REDIS_URL="redis://localhost:6379"
APP_BASE_URL="http://localhost:3000"
API_PORT="4000"

# Auth (managed provider)
# Clerk publishable key for apps/web.
AUTH_PROVIDER_KEY=""
# Optional Clerk-hosted auth URLs for the public login/signup pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=""
NEXT_PUBLIC_CLERK_SIGN_UP_URL=""
# Clerk secret key for apps/api.
AUTH_PROVIDER_SECRET=""
# Comma-separated emails that are promoted to ADMIN on first authenticated API request.
ADMIN_EMAILS=""

# MetaApi
METAAPI_TOKEN=""
METAAPI_REGION=""

# AI
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
AI_MODEL_ANTHROPIC="claude-sonnet-4-6"
AI_MODEL_OPENAI="gpt-4.1-mini"
AI_MAX_TOKENS_PER_USER_DAILY="50000"

# Alerts email (optional; in-app alerts work without these)
EMAIL_PROVIDER=""
RESEND_API_KEY=""
ALERTS_FROM_EMAIL=""

# Storage
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_SECRET=""

# Security / Observability
ENCRYPTION_KEY=""
SENTRY_DSN=""
CORS_EXTRA_ORIGINS=""
JSON_BODY_LIMIT="1mb"
